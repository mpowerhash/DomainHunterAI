# -------------------------------------------------------
# DomainHunterAI — Environment Variables
# Copy this file to .env and fill in your keys.
# The app works in mock mode with no keys at all.
# -------------------------------------------------------

# OpenAI (optional)
# If present: enables AI-powered domain generation via gpt-4o-mini.
# If missing: app uses rule-based mock generator automatically.
OPENAI_API_KEY=

# GoDaddy (optional)
# If both vars are present: enables live availability checks AND real pricing.
# Priority: GoDaddy > Namecheap > mock.
GODADDY_API_KEY=
GODADDY_API_SECRET=

# Namecheap (optional)
# If all four vars are present: enables live availability checks (no pricing).
# Only used if GoDaddy is not configured.
NAMECHEAP_API_USER=
NAMECHEAP_API_KEY=
NAMECHEAP_USERNAME=
NAMECHEAP_CLIENT_IP=
